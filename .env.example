# Copy to .env and set values. Do not commit .env (it may contain secrets).

# ---------------------------------------------------------------------------
# Inference provider: ollama (local), huggingface (serverless), or openai
# ---------------------------------------------------------------------------
# INFERENCE_PROVIDER=ollama
# INFERENCE_PROVIDER=huggingface
# INFERENCE_PROVIDER=openai

# ---------------------------------------------------------------------------
# Ollama (used when INFERENCE_PROVIDER=ollama or unset)
# ---------------------------------------------------------------------------
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text:v1.5
# OLLAMA_LLM_MODEL=llama3.1:8b

# ---------------------------------------------------------------------------
# Hugging Face (used when INFERENCE_PROVIDER=huggingface)
# Get token: https://huggingface.co/settings/tokens (needs Inference Providers permission)
# ---------------------------------------------------------------------------
# HUGGINGFACEHUB_API_TOKEN=your_hf_token_here
# HF_TOKEN=your_hf_token_here

# Optional: override embedding/LLM models (HF)
# HF_EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2
# HF_LLM_MODEL=meta-llama/Llama-3.1-8B-Instruct

# ---------------------------------------------------------------------------
# OpenAI (used when INFERENCE_PROVIDER=openai)
# Get key: https://platform.openai.com/api-keys
# ---------------------------------------------------------------------------
# OPENAI_API_KEY=your_openai_api_key_here
# Optional: override base URL (for Azure / proxy, must end with /v1)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: override embedding/LLM models (OpenAI)
# OPENAI_EMBEDDING_MODEL=text-embedding-3-large
# OPENAI_LLM_MODEL=gpt-4o-mini


# ---------------------------------------------------------------------------
# DeepSeek OCR (used by detectiondeepseek.py for image/PDF OCR)
# Option A (recommended): Ollama – run `ollama pull deepseek-ocr:3b` then set:
# ---------------------------------------------------------------------------
# DEEPSEEK_OCR_OLLAMA_MODEL=deepseek-ocr:3b
# Optional: Ollama base URL (defaults to OLLAMA_BASE_URL or http://localhost:11434)
# DEEPSEEK_OCR_OLLAMA_BASE_URL=http://localhost:11434

# Option B: Local Hugging Face model (download weights on first run)
# DEEPSEEK_OCR_USE_LOCAL=1
# DEEPSEEK_OCR_MODEL_PATH=deepseek-ai/DeepSeek-OCR

# Option C: DeepSeek OCR cloud API
# DEEPSEEK_OCR_API_KEY=your_deepseek_ocr_api_key_here
# DEEPSEEK_OCR_BASE_URL=https://api.deepsee-ocr.ai

# Optional: DPI for PDF page rendering when using DeepSeek fallback (default: 200)
# DEEPSEEK_OCR_PDF_DPI=200
